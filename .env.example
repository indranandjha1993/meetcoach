# Optional: Deepgram for low-latency cloud STT (recommended for live meetings).
# Without this key, meetcoach falls back to local faster-whisper.
DEEPGRAM_API_KEY=

# Optional: override the Claude CLI binary if it isn't on PATH.
# CLAUDE_BIN=/usr/local/bin/claude

# Optional: model passed to claude -p (defaults to whatever your CLI uses).
# COACH_MODEL=claude-haiku-4-5
